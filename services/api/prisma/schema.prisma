  title         String?
  description   String?           @db.Text
  mediaUrls     String[]          @default([])
  socialUrl     String?
  platform      String?
  productId     String?
  product       Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  fandomId      String?
  fandom        Fandom?           @relation(fields: [fandomId], references: [id], onDelete: SetNull)
  status        String            @default("PENDING")
  pointsAwarded Int               @default(0)
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewNotes   String?           @db.Text
  featuredAt    DateTime?
  metadata      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([ambassadorId])
  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([productId])
  @@map("ugc_submissions")
}

model AmbassadorAchievement {
  id              String            @id @default(uuid())
  ambassadorId    String
  ambassador      AmbassadorProfile @relation(fields: [ambassadorId], references: [id], onDelete: Cascade)
  achievementSlug String
  name            String
  description     String?
  icon            String?
  pointsAwarded   Int               @default(0)
  unlockedAt      DateTime          @default(now())

  @@unique([ambassadorId, achievementSlug])
  @@index([ambassadorId])
  @@map("ambassador_achievements")
}

model LoyaltyBonusCampaign {
  id           String    @id @default(uuid())
  name         String
  description  String?   @db.Text
  type         String
  multiplier   Decimal?  @db.Decimal(3, 2)
  bonusPoints  Int?
  conditions   Json?
  regionCodes  String[]  @default([])
  channelCodes String[]  @default([])
  isActive     Boolean   @default(true)
  startsAt     DateTime
  endsAt       DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  brandCampaignId String?        @unique
  brandCampaign   BrandCampaign? @relation(fields: [brandCampaignId], references: [id], onDelete: SetNull)

  @@index([isActive, startsAt, endsAt])
  @@map("loyalty_bonus_campaigns")
}

model BrandPartnership {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  contactName   String?
  contactEmail  String?
  logoUrl       String?
  description   String?  @db.Text
  status        String   @default("ACTIVE")
  contractStart DateTime
  contractEnd   DateTime
  totalBudget   Decimal  @default(0) @db.Decimal(10, 2)
  spentBudget   Decimal  @default(0) @db.Decimal(10, 2)
  currency      String   @default("GBP")
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaigns BrandCampaign[]

  @@index([status])
  @@index([slug])
  @@map("brand_partnerships")
}

model BrandCampaign {
  id                 String           @id @default(uuid())
  partnershipId      String
  partnership        BrandPartnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
  name               String
  slug               String           @unique
  description        String?          @db.Text
  type               String           @default("MULTIPLIER")
  status             String           @default("DRAFT")
  startsAt           DateTime
  endsAt             DateTime
  multiplier         Decimal?         @db.Decimal(3, 2)
  bonusPoints        Int?
  maxPointsPerUser   Int?
  totalPointsBudget  Int?
  targetFandoms      String[]         @default([])
  targetBrands       String[]         @default([])
  targetCategoryIds  String[]         @default([])
  targetProductIds   String[]         @default([])
  segmentId          String?
  minTierLevel       Int              @default(0)
  regionCodes        String[]         @default([])
  totalPointsAwarded Int              @default(0)
  totalOrders        Int              @default(0)
  totalRevenue       Decimal          @default(0) @db.Decimal(10, 2)
  uniqueUsers        Int              @default(0)
  featuredProductIds String[]         @default([])
  exclusiveTierLevel Int?
  journeySlug        String?
  notifyOnStart      Boolean          @default(true)
  metadata           Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  redemptions   BrandCampaignRedemption[]
  loyaltyMirror LoyaltyBonusCampaign?

  @@index([partnershipId])
  @@index([status])
  @@index([startsAt, endsAt])
  @@map("brand_campaigns")
}

model BrandCampaignRedemption {
  id            String        @id @default(uuid())
  campaignId    String
  campaign      BrandCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId       String?
  pointsAwarded Int
  orderTotal    Decimal?      @db.Decimal(10, 2)
  source        String        @default("PURCHASE")
  createdAt     DateTime      @default(now())

  @@index([campaignId])
  @@index([userId])
  @@index([campaignId, userId])
  @@map("brand_campaign_redemptions")
}

model ProductChannel {
  id             String    @id @default(uuid())
  productId      String
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  channelType    String
  storeId        String?
  store          Store?    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  currency       String
  sellingPrice   Decimal   @db.Decimal(10, 2)
  costPrice      Decimal?  @db.Decimal(10, 2)
  compareAtPrice Decimal?  @db.Decimal(10, 2)
  marginPercent  Decimal?  @db.Decimal(5, 4)
  batchReference String?
  effectiveFrom  DateTime  @default(now())
  effectiveUntil DateTime?
  isActive       Boolean   @default(true)
  assignedBy     String?
  notes          String?   @db.Text

  @@unique([productId, channelType, storeId, currency, effectiveFrom])
  @@index([productId])
  @@index([channelType])
  @@index([storeId])
  @@index([isActive])
  @@map("product_channels")
}

model POSConnection {
  id                 String    @id @default(uuid())
  sellerId           String
  seller             Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  storeId            String    @unique
  store              Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  provider           String
  credentials        String
  externalOutletId   String?
  externalRegisterId String?
  webhookSecret      String?
  autoSyncProducts   Boolean   @default(true)
  autoSyncInventory  Boolean   @default(true)
  syncIntervalMinutes Int      @default(60)
  isActive           Boolean   @default(true)
  lastSyncedAt       DateTime?
  syncStatus         String    @default("NEVER_SYNCED")
  syncError          String?   @db.Text
  settings           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([sellerId, storeId])
  @@index([provider])
  @@index([isActive])
  @@map("pos_connections")
}

model POSSale {
  id                    String        @id @default(uuid())
  storeId               String
  store                 Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  externalSaleId        String
  externalInvoice       String?
  provider              String
  saleDate              DateTime
  customerId            String?
  customerEmail         String?
  totalAmount           Decimal       @db.Decimal(10, 2)
  currency              String        @default("GBP")
  taxAmount             Decimal       @default(0) @db.Decimal(10, 2)
  discountAmount        Decimal       @default(0) @db.Decimal(10, 2)
  loyaltyPointsEarned   Int           @default(0)
  loyaltyPointsRedeemed Int           @default(0)
  items                 POSSaleItem[]
  status                String        @default("IMPORTED")
  rawPayload            Json?
  importedAt            DateTime      @default(now())
  processedAt           DateTime?

  @@unique([provider, externalSaleId])
  @@index([storeId])
  @@index([customerId])
  @@index([saleDate])
  @@map("pos_sales")
}

model POSSaleItem {
  id                String   @id @default(uuid())
  saleId            String
  sale              POSSale  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId         String?
  product           Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  externalProductId String?
  sku               String?
  name              String
  quantity          Int
  unitPrice         Decimal  @db.Decimal(10, 2)
  totalPrice        Decimal  @db.Decimal(10, 2)
  taxAmount         Decimal  @default(0) @db.Decimal(10, 2)

  @@index([saleId])
  @@index([productId])
  @@map("pos_sale_items")
}

model ExternalEntityMapping {
  id           String    @id @default(uuid())
  provider     String
  entityType   String
  internalId   String
  externalId   String
  storeId      String?
  metadata     Json?
  lastSyncedAt DateTime?
  syncStatus   String    @default("SYNCED")
  syncError    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([provider, entityType, internalId, storeId])
  @@unique([provider, entityType, externalId, storeId])
  @@index([provider, entityType])
  @@index([syncStatus])
  @@map("external_entity_mappings")
}

// === Phase 4 — Marketing automation ===

model MarketingJourney {
  id                 String   @id @default(uuid())
  slug               String   @unique
  name               String
  description        String?  @db.Text
  triggerEvent       String
  triggerConditions  Json?
  steps              Json
  isActive           Boolean  @default(true)
  regionCodes        String[] @default([])
  channelCodes       String[] @default([])
  segmentId          String?
  segment            AudienceSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  enrollments JourneyEnrollment[]

  @@index([triggerEvent])
  @@index([isActive])
  @@index([segmentId])
  @@map("marketing_journeys")
}

model AudienceSegment {
  id              String    @id @default(uuid())
  slug            String    @unique
  name            String
  description     String?   @db.Text
  type            String    @default("DYNAMIC")
  status          String    @default("ACTIVE")
  rules           Json
  memberCount     Int       @default(0)
  lastEvaluatedAt DateTime?
  refreshCron     String?
  isTemplate      Boolean   @default(false)
  templateSlug    String?   @unique
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  members  SegmentMembership[]
  journeys MarketingJourney[]

  @@index([status])
  @@index([type])
  @@index([isTemplate])
  @@map("audience_segments")
}

model SegmentMembership {
  id        String          @id @default(uuid())
  segmentId String
  segment   AudienceSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime        @default(now())
  metadata  Json?

  @@unique([segmentId, userId])
  @@index([userId])
  @@index([segmentId])
  @@map("segment_memberships")
}

model JourneyEnrollment {
  id          String   @id @default(uuid())
  journeyId   String
  journey     MarketingJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStep Int      @default(0)
  status      String   @default("ACTIVE")
  startedAt   DateTime @default(now())
  completedAt DateTime?
  lastStepAt  DateTime?
  nextStepAt  DateTime?
  metadata    Json?

  @@unique([journeyId, userId])
  @@index([userId])
  @@index([status, nextStepAt])
  @@map("journey_enrollments")
}

model MessageLog {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel       String
  templateSlug  String?
  subject       String?
  status        String    @default("QUEUED")
  journeyId     String?
  enrollmentId  String?
  providerRef   String?
  error         String?   @db.Text
  sentAt        DateTime?
  deliveredAt   DateTime?
  openedAt      DateTime?
  clickedAt     DateTime?
  metadata      Json?
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([channel, status])
  @@index([journeyId])
  @@index([createdAt])
  @@map("message_logs")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @db.Text
  keys      Json
  platform  String   @default("WEB")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
  @@map("push_subscriptions")
}

// === Phase 5 — Event & experience management ===

model Event {
  id               String    @id @default(uuid())
  title            String
  slug             String    @unique
  description      String?   @db.Text
  shortDescription String?
  type             String    @default("IN_STORE")
  status           String    @default("DRAFT")
  imageUrl         String?
  bannerUrl        String?

  storeId      String?
  store        Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)
  venueName    String?
  venueAddress String?

  virtualUrl      String?
  virtualPlatform String?

  startsAt    DateTime
  endsAt      DateTime
  timezone    String    @default("Europe/London")
  doorsOpenAt DateTime?

  capacity       Int?
  isPublic       Boolean  @default(true)
  minTierLevel   Int      @default(0)
  allowedTierIds String[] @default([])
  requiresTicket Boolean  @default(false)
  ticketPrice    Decimal? @db.Decimal(10, 2)
  ticketCurrency String   @default("GBP")

  attendancePoints Int     @default(100)
  earnRuleAction   String?

  fandomId String?
  fandom   Fandom?  @relation(fields: [fandomId], references: [id], onDelete: SetNull)
  tags     String[] @default([])

  hostName String?
  hostBio  String?  @db.Text
  agenda   Json?
  metadata Json?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rsvps       EventRSVP[]
  attendances EventAttendance[]

  @@index([storeId])
  @@index([fandomId])
  @@index([status])
  @@index([startsAt])
  @@index([type])
  @@index([minTierLevel])
  @@map("events")
}

model EventRSVP {
  id          String    @id @default(uuid())
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String    @default("CONFIRMED")
  guestCount  Int       @default(0)
  ticketCode  String?   @unique
  notes       String?
  rsvpAt      DateTime  @default(now())
  cancelledAt DateTime?
  metadata    Json?

  @@unique([eventId, userId])
  @@index([userId])
  @@index([status])
  @@index([ticketCode])
  @@map("event_rsvps")
}

model EventAttendance {
  id            String   @id @default(uuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkedInAt   DateTime @default(now())
  checkedInBy   String?
  method        String   @default("QR_SCAN")
  pointsAwarded Int      @default(0)
  transactionId String?
  metadata      Json?

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId])
  @@map("event_attendances")
}
