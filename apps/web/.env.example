# =============================================================================
# House of Spells - Web App Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ are available in the browser.

# API URL (Required) — Backend API base URL. Must be set at BUILD TIME.
NEXT_PUBLIC_API_URL=https://hos-marketplaceapi-production.up.railway.app

# Site URL (Required for SEO) — Canonical URL for sitemap, robots.txt, Open Graph
NEXT_PUBLIC_SITE_URL=https://hos-marketplaceweb-production.up.railway.app

# Google Analytics 4 — Measurement ID (e.g. G-XXXXXXXXXX). Loads gtag.js when set.
# If GTM is also set, configure GA4 inside GTM instead and leave this empty to avoid duplicate page views.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager — Container ID (e.g. GTM-XXXXXXX). Use for GA4, Google Ads, and other marketing pixels.
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Meta Pixel — Facebook/Meta tracking (browser-side, requires marketing consent)
# NEXT_PUBLIC_META_PIXEL_ID=123456789012345

# Meta Conversions API — Server-side token (never expose to browser)
# META_CONVERSIONS_API_TOKEN=your-capi-access-token

# Meta Test Events — Optional code for debugging in Events Manager
# META_TEST_EVENT_CODE=TEST12345

# Google Search Console — HTML tag verification content value
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# Footer social icons (full https URLs — optional; omit to hide icons in footer)
# NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=https://www.facebook.com/your-page
# NEXT_PUBLIC_SOCIAL_X_URL=https://x.com/your-handle
# NEXT_PUBLIC_SOCIAL_TWITTER_URL=https://twitter.com/your-handle
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=https://www.instagram.com/your-handle

# CMS URL (Optional) — Strapi CMS URL for content management
# NEXT_PUBLIC_CMS_URL=https://your-cms.railway.app/api

# App URL (Optional) — Used for CMS webhook revalidation
# NEXT_PUBLIC_APP_URL=https://hos-marketplaceweb-production.up.railway.app

# CMS Revalidate Secret (Optional, server-side only) — Secret for CMS webhook auth
# CMS_REVALIDATE_SECRET=your-revalidate-secret

# Stripe (Required for card payments in the browser)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
