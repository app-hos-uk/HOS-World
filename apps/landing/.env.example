# House of Spells Landing Page
# Copy to .env.local for local development

# API URL for founding member registration
NEXT_PUBLIC_API_URL=https://hos-marketplaceapi-production.up.railway.app/api

# Canonical site URL (used for OG images, JSON-LD, canonical links)
# MUST be set in production — otherwise og:image points to localhost
NEXT_PUBLIC_SITE_URL=https://houseofspells.com

# Shop URL (set when e-commerce is live; shows "Enter Shop" link in nav)
# NEXT_PUBLIC_SHOP_URL=https://shop.houseofspells.com

# Analytics — Google Analytics 4 measurement ID
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Analytics — Meta (Facebook) Pixel ID
# NEXT_PUBLIC_META_PIXEL_ID=000000000000000
