# Keep Docker build context small
.pnpm-store/

# Dependencies / builds
node_modules/
**/node_modules/
.next/
**/.next/
dist/
**/dist/
coverage/
**/coverage/

# Exclude non-essential dirs (do not exclude apps/ — web Dockerfile needs apps/web with context at repo root)
docs/
# Root `pnpm install` runs prepare → scripts/setup-git-hooks.mjs; Dockerfiles COPY that file — it must stay in context.
scripts/*
!scripts/setup-git-hooks.mjs
.github/
services/api/test/
**/*.spec.ts
**/*.test.ts
**/*.md
LICENSE

# VCS / IDE
.git/
.idea/
.vscode/
.cursor/

# Logs
*.log
logs/

# Local env
.env
.env*.local

